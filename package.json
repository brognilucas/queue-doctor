{
  "name": "queuedoctor",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter queue-doctor build && pnpm --filter @queuedoctor/web dev",
    "build": "pnpm --filter queue-doctor build && pnpm --filter @queuedoctor/web build",
